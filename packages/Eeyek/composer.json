{
  "name": "mpdf/font-eeyek",
  "version": "0.1",
  "type": "library",
  "description": "Eeyek is a Unicode font for the Meetei Mayek script. Supported scripts include: Meetei Mayek and Latin",
  "keywords": ["mpdf", "mpdf-fonts"],
  "license": ["MIT"],
  "autoload": {
    "psr-4": {
      "Mpdf\\Fonts\\Eeyek\\": ""
    }
  },
  "require": {
    "mpdf/mpdf": "*"
  },
  "extra": {
    "mpdf": {
      "fonts": "\\Mpdf\\Fonts\\Eeyek\\Registration"
    }
  }
}